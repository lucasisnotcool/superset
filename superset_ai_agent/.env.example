# Single AI agent env file used by native development and Docker Compose.
# Docker Compose reads this file, then overrides only container-network topology
# such as SUPERSET_BASE_URL.

AI_AGENT_MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
AI_AGENT_MODEL=qwen2.5-coder:7b
AI_AGENT_DEFAULT_SQL_LIMIT=1000
AI_AGENT_MAX_REPAIR_ATTEMPTS=1
AI_AGENT_MAX_CONTEXT_DATASETS=8
AI_AGENT_MAX_SAMPLE_ROWS=5
# Persistence is ON by default so MDL, conversations, and the materialized
# manifest survive restarts. Use "memory" only for ephemeral dev/tests.
AI_AGENT_CONVERSATION_STORE=sqlalchemy
AI_AGENT_SEMANTIC_LAYER_STORE=sqlalchemy
AI_AGENT_IDENTITY_PROVIDER=superset_session
AI_AGENT_ALLOW_STATIC_IDENTITY_WITH_PERSISTENCE=false
AI_AGENT_SIGNED_IDENTITY_HEADER=X-Superset-Ai-Agent-Identity
AI_AGENT_SIGNED_IDENTITY_SECRET=
AI_AGENT_DATABASE_URL=sqlite:///./.data/ai_agent.db
AI_AGENT_DATABASE_ECHO=false
# Migrations run to head on startup. Migration 0004 one-time purges legacy
# YAML/snake-case MDL rows from before the native-JSON rebuild (fresh installs
# purge nothing). To purge manually instead, run:
#   python -m superset_ai_agent.scripts.purge_legacy_mdl --apply
AI_AGENT_RUN_MIGRATIONS=true
AI_AGENT_MIGRATION_BOOTSTRAP=error
AI_AGENT_STORAGE_DIR=./.data
AI_AGENT_DOCUMENT_STORAGE=local
AI_AGENT_DOCUMENT_S3_BUCKET=
AI_AGENT_DOCUMENT_S3_PREFIX=superset-ai-agent/documents
AI_AGENT_DOCUMENT_S3_ENDPOINT_URL=
AI_AGENT_DOCUMENT_S3_REGION_NAME=
AI_AGENT_MAX_HISTORY_MESSAGES=12
AI_AGENT_MAX_PROMPT_RESULT_ROWS=5
AI_AGENT_MAX_SQL_ITERATIONS=3
AI_AGENT_LOG_LEVEL=INFO
AI_AGENT_SUPPRESS_SUPERSET_LOGS=true
AI_AGENT_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8090,http://127.0.0.1:8090,http://localhost:8092,http://127.0.0.1:8092

# Wren semantic context and planning. Wren is read-only in the agent; execution
# remains disabled and SQL still runs only through SupersetClient.
WREN_ENABLED=true
# llm = in-process modeling brain (onboarding/enrichment/query context). This is
# the full-parity adapter; "file"/"http" are alternate drop-ins.
WREN_ADAPTER=llm
WREN_BASE_URL=
WREN_API_KEY=
WREN_TIMEOUT_SECONDS=30
# Schema onboarding -> draft base MDL is enabled.
WREN_ONBOARDING_ENABLED=true
WREN_PROJECT_PATH=
WREN_MDL_PATH=
WREN_MEMORY_PATH=
WREN_DRY_PLAN_ENABLED=true
# Execution stays OFF — the semantic engine rewrites; Superset is the only executor.
WREN_EXECUTION_ENABLED=false
WREN_CONTEXT_LIMIT=8
WREN_EXAMPLE_LIMIT=5
WREN_SCHEMA_TABLE_SCAN_LIMIT=100
WREN_SCHEMA_TABLE_CANDIDATE_LIMIT=12
WREN_SCHEMA_METRIC_CANDIDATE_LIMIT=20
WREN_SCHEMA_EXAMPLE_CANDIDATE_LIMIT=5
WREN_SCHEMA_DOCUMENT_CANDIDATE_LIMIT=5
WREN_SCHEMA_CONTEXT_TOKEN_BUDGET=6000
WREN_REQUIRE_SCHEMA_SCOPE=true
WREN_MAX_DOCUMENT_BYTES=10000000
# Uploads larger than this extract on a background thread instead of inline
# (Office files / large PDFs can be slow); status is tracked on the document row.
WREN_DOCUMENT_ASYNC_THRESHOLD_BYTES=1000000
# PDF/DOCX/XLSX/PPTX need pypdf/python-docx/openpyxl/python-pptx (installed via
# requirements-ai-agent.txt) -- all pure-Python, no Microsoft Office/LibreOffice
# needed; CSV/JSON/HTML extraction is stdlib. A missing extractor dep records
# status="error" (not a crash); an image-only PDF records status="needs_ocr".
WREN_ALLOWED_DOCUMENT_TYPES=text/plain,text/markdown,text/csv,application/json,text/html,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation
# C4: document chunking. Ingestion retains whole sections up to EXTRACT_CHAR_LIMIT
# (was a hard 20k head cut); enrichment then assembles the schema-relevant sections
# within PROMPT_CHAR_BUDGET, so a large document's late content about real tables
# survives instead of only the head. Retention >> budget on purpose. 0 = no limit.
WREN_DOCUMENT_EXTRACT_CHAR_LIMIT=200000
WREN_DOCUMENT_PROMPT_CHAR_BUDGET=20000
# Uploaded-document RAG + CRUD (uploaded_documents_rag_and_crud.md). When ON,
# uploads are chunked + embedded at ingestion and the chunk/retrieve/dedup/CRUD
# routes + viewer are exposed. Documents use their OWN LanceDB directory
# (WREN_DOCUMENT_LANCEDB_PATH) so the MDL/sql_pairs/instructions index is untouched.
# Embedding-backed cosine recall requires an embedder (configured below); it
# degrades closed to keyword recall otherwise.
WREN_DOCUMENT_INDEXING_ENABLED=true
WREN_DOCUMENT_VECTOR_INDEX=lancedb
WREN_DOCUMENT_LANCEDB_PATH=./.data/wren_lancedb_documents
WREN_DOCUMENT_RETRIEVE_K=8
WREN_DOCUMENT_DUP_THRESHOLD=0.92
# OCR seam (reserved). Image-only PDFs are tagged status="needs_ocr"; no OCR runs.
WREN_DOCUMENT_OCR_ENABLED=false
# MDL Copilot (wren_mdl_copilot.md): agentic CRUD editor + workspace tree + the
# read-only document grounding tools. Required for the document agent tools.
WREN_COPILOT_ENABLED=true
# Auto-pilot (plan_copilot_enrichment_assertiveness.md): the copilot makes its best
# inferences and proposes them directly into the review-gated changeset — including
# relationships and metrics — instead of asking first (grill mode). Every proposal
# is still a human-accepted draft; nothing is persisted/activated without review.
# Code default false; ENABLED here so enrichment is assertive (relationships +
# metrics, not just descriptions).
WREN_COPILOT_AUTOPILOT_ENABLED=true
# Prior Copilot turns fed back into the edit loop as multi-turn memory (mirrors
# AI_AGENT_MAX_HISTORY_MESSAGES). Copilot threads persist via the shared
# conversation store, so this needs AI_AGENT_CONVERSATION_STORE=sqlalchemy for
# cross-worker/durable history.
WREN_COPILOT_MAX_HISTORY_MESSAGES=12
# Max tool-calling turns in the agentic MDL-edit loop before it finalizes. A
# capable model enriching many files (schema -> list -> read each -> write each ->
# validate) can need well over the legacy default of 8; raise for large projects.
# An overrun returns a labeled partial changeset (re-run to continue), never a
# silent dead turn. Recommended range 8-24.
WREN_COPILOT_MAX_STEPS=16
# --- MDL coverage audit + recovery (MDL_PROVENANCE_AND_COVERAGE.md) --------
# Background directory coverage (Feature B): auto-run a reverse-reconciliation
# audit (what % of the source docs the MDL captures) when the active MDL set
# changes. Produces the coverage badge/version label. Code default true.
WREN_COVERAGE_AUTO_ENABLED=true
# Coverage recovery agent: after a coverage run finds gaps, an MDL Copilot turn
# proposes edits to close them as a reviewable changeset (never auto-applied).
# Surfaces the "Coverage suggestions ready" banner + review dialog. Code default
# FALSE — set true here to enable the recovery banner/dialog in the UI.
WREN_COVERAGE_RECOVERY_ENABLED=true
# Autonomous coverage+recovery sweep interval (seconds). When > 0, a background
# thread periodically (and shortly after startup) runs two INDEPENDENT passes:
#   1. coverage — schedule an audit for any project whose latest MDL version has
#      no completed coverage report (picks up legacy / pre-feature projects);
#   2. recovery — schedule the recovery agent for any project whose latest
#      completed report has gaps but no (or failed) suggestions yet.
# The two passes are decoupled: recovery does not require a fresh coverage run.
# 0 disables the sweep (purely event-driven, as before). Recommended 900 (15m).
WREN_COVERAGE_SWEEP_INTERVAL_SECONDS=900
AI_AGENT_SEMANTIC_ACCESS_MODE=superset_or_uri
AI_AGENT_SEMANTIC_FULL_ACCESS_GRANTS_WRITE=false

# --- Wren full-parity seams (see wren_full.md) ----------------------------
# These are set for FULL Wren parity with persistence across sessions. Each
# requires durable persistence (AI_AGENT_SEMANTIC_LAYER_STORE=sqlalchemy, set
# above and enforced at startup) so models, the materialized manifest, and
# learned examples survive restarts.
# Engine: wren_core (semantic rewrite) | passthrough (LLM writes native SQL).
# wren-core-py is a hard dependency; the engine degrades to passthrough when a
# query backend has no wren-core dialect (e.g. sqlite) or no MDL for the scope.
WREN_ENGINE=wren_core
# Deep MDL validation via wren-core at activation time.
WREN_CORE_VALIDATION_ENABLED=true
# F0.1: require the wren-core engine for activation. When true, activation fails
# closed (409) if wren-core is not installed and runs deep engine validation —
# instead of silently degrading to structural-only. Code default false; ENABLED
# here for full parity (engine as the authority) — wren-core-py is installed by
# default (requirements-ai-agent.txt).
WREN_ACTIVATION_REQUIRES_ENGINE=true
# E3: authoring-side correction loop. When > 0, an enrichment proposal that fails
# structural validation is re-drafted up to N times with the errors fed back to
# the model. The modeling analogue of WREN_ENGINE_MAX_CORRECTION_RETRIES.
WREN_MODELING_MAX_CORRECTION_RETRIES=1
# C2.1: run wren-core *deep* validation inside the enrichment correction loop, so
# expression errors (calculated fields, metrics, relationship expressions) are
# caught + repaired at draft time, not only at activation. The overlay is merged
# against the full active MDL first. No-op without wren-core. Code default false;
# ENABLED here for full parity (engine-authoritative validation at draft time:
# adds an engine compile per draft and surfaces validation failures earlier).
WREN_MODELING_DEEP_VALIDATION=true
# Instruct the LLM to author semantic SQL against MDL models; the engine rewrites
# it to native SQL (active when engine != passthrough).
WREN_SEMANTIC_SQL_ENABLED=true
# Engine-feedback correction loop (1.4): when > 0, re-draft semantic SQL up to N
# times if the engine flags a hallucinated model/table the draft can't resolve.
# Code default 0 (off); ENABLED here for full parity (Wren's engine-error-driven
# sql_correction loop). Dry-plan diagnostics also fold into SQL repair.
WREN_ENGINE_MAX_CORRECTION_RETRIES=1
# Retrieval: keyword (token overlap) | embedding (vector similarity). Embedding
# needs an embedder (below); it degrades to keyword until one is configured.
WREN_RETRIEVER=embedding
# Where embedding-retrieval vectors live: memory (in-process, rebuilt per worker)
# or lancedb (persistent across restarts/workers). lancedb is import-guarded;
# absent → falls back to memory. Code default memory; set to lancedb here for the
# full-parity persistent store (lancedb wheel installed by default; set
# WREN_LANCEDB_PATH below so the index survives restarts).
WREN_VECTOR_INDEX=lancedb
# Bound the in-process retriever index to the N most-recently-used scopes so a
# worker serving many projects/owners cannot grow unbounded. 0 = unlimited.
WREN_RETRIEVER_CACHE_SCOPES=64
# Total cap on merged prompt context items (MDL chunks + fetch_context) so a wide
# schema cannot inflate the prompt. Retrieval-ranked
# chunks win on overflow. 0 = unlimited.
WREN_MAX_CONTEXT_ITEMS=40
# R2 table-selection: narrow the ranked MDL chunks to the top-N most relevant
# models (coherent per-table context, Wren-style) before merging. Relationship/
# model-less chunks are always kept. 0 = off (count cap only).
WREN_TABLE_SELECTION_LIMIT=5
# C1.3: use an LLM to pick the relevant model subset (Wren's table/column selection)
# instead of the heuristic top-N. Adds one model call to the retrieval node; degrades
# closed to WREN_TABLE_SELECTION_LIMIT on any failure. Code default false; ENABLED
# here for full parity (Wren's LLM table-selection re-rank).
WREN_LLM_TABLE_SELECTION=true
# Memory learning loop: confirmed NL->SQL pairs persist across sessions in the
# agent DB and are recalled as few-shot. sqlalchemy = durable across restarts;
# lancedb = durable + a persistent `sql_pairs`/`instructions` vector cache so
# recall embeds each pair/instruction once at write time (ANN lookup) instead of
# re-embedding the candidate set per query (plan C0). lancedb needs an embedder
# (below) and the lancedb wheel; it degrades to sqlalchemy when either is absent.
# Recommended prod topology: an embedder + WREN_VECTOR_INDEX=lancedb +
# WREN_MEMORY_STORE=lancedb (one persistent store, many collections — Wren parity).
# Set to lancedb here for that full-parity topology (degrades to sqlalchemy without
# an embedder/wheel, then to in-memory without a durable DB).
WREN_MEMORY_STORE=lancedb
WREN_MEMORY_LEARNING_ENABLED=true
WREN_MEMORY_RECALL_K=3
# Instructions (Wren-style operator guidance): how many non-global instructions
# to retrieve by similarity per question (global ones always apply). Instructions
# share the agent DB (durable when WREN_MEMORY_STORE=sqlalchemy).
WREN_INSTRUCTION_RECALL_K=3
# Decay: cap confirmed examples kept per owner+scope; oldest evicted past this.
# 0 = unlimited.
WREN_MEMORY_MAX_EXAMPLES=200
# Classify question intent (text_to_sql | general | clarify) before drafting a
# conversation turn and pass the label to the model as a hint. Off by default
# (adds one LLM call/turn); the model already routes answer-vs-SQL well.
WREN_INTENT_CLASSIFICATION_ENABLED=false
# Routing short-circuit (RO1a): when on (needs classification on), general/clarify
# answers directly and skips context-load + SQL. Off by default — a misclassified
# data question would get a non-answer.
WREN_INTENT_ROUTING_ENABLED=false
# Embeddings for WREN_RETRIEVER=embedding. REQUIRED for the full-parity topology
# above: embedding retrieval, the lancedb persistent index, and the lancedb
# `sql_pairs`/`instructions` caches all need an available embedder, else they
# degrade closed (embedding→keyword, lancedb→sqlalchemy). The embedder reuses
# OPENAI_API_KEY / OPENAI_BASE_URL when the overrides below are unset — so fill
# AI_AGENT_EMBEDDER_API_KEY here OR OPENAI_API_KEY (below) to activate parity.
AI_AGENT_EMBEDDER_PROVIDER=openai
AI_AGENT_EMBEDDER_MODEL=text-embedding-3-small
AI_AGENT_EMBEDDER_DIMENSIONS=1536
AI_AGENT_EMBEDDER_API_KEY=
AI_AGENT_EMBEDDER_BASE_URL=
AI_AGENT_EMBEDDER_BATCH_SIZE=128
# Persistent vector index / cache dir for WREN_VECTOR_INDEX=lancedb and
# WREN_MEMORY_STORE=lancedb. Set for full parity so the db_schema index and the
# sql_pairs/instructions caches survive restarts; blank uses in-memory cosine.
WREN_LANCEDB_PATH=./.data/wren_lancedb

# OpenAI provider. Required only when AI_AGENT_MODEL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Generic OpenAI-compatible provider. Required only when
# AI_AGENT_MODEL_PROVIDER=openai_compatible.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_REQUIRE_API_KEY=true
OPENAI_COMPATIBLE_STRUCTURED_OUTPUT=json_schema

# Azure OpenAI provider. Required only when AI_AGENT_MODEL_PROVIDER=azure_openai.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_STRUCTURED_OUTPUT=json_schema

# Superset adapter boundary. REST is the default for native and Docker parity.
# In the normal Docker UI flow, browser requests go through nginx at
# http://localhost:8090 and the agent reuses the logged-in Superset session.
# Docker Compose overrides SUPERSET_BASE_URL to http://superset:8088.
SUPERSET_AGENT_ADAPTER=rest
SUPERSET_AUTH_MODE=user_session
SUPERSET_BASE_URL=http://localhost:8091
SUPERSET_MCP_URL=http://localhost:8098/mcp

# Deployment environment (development | production). In production the agent
# refuses to boot with SUPERSET_AGENT_ADAPTER=local or
# SUPERSET_AUTH_MODE=service_account, because both bypass per-user Superset
# authorization, leaving the SQL safety policy as the only guard (R-CFG).
AI_AGENT_ENV=development

# SQL safety policy strictness (strict | permissive). The agent classifies
# generated SQL with Superset's own parser and only auto-runs read-only
# statements. ``strict`` (default) blocks every multi-statement script;
# ``permissive`` allows a script only when EVERY statement in it is read-only.
# Neither mode can ever auto-run a write — that always requires the database's
# own authorization on the REST path.
AI_AGENT_SQL_POLICY=strict

# Service-account fallback. These are ignored when SUPERSET_AUTH_MODE=user_session.
# For direct native API testing without a proxied Superset browser session, set
# SUPERSET_AUTH_MODE=service_account and fill one auth method below.
SUPERSET_AUTH_TOKEN=
SUPERSET_USERNAME=
SUPERSET_PASSWORD=
SUPERSET_AUTH_PROVIDER=db
SUPERSET_CSRF_TOKEN=
SUPERSET_SQL_POLL_ATTEMPTS=10
SUPERSET_SQL_POLL_INTERVAL_SECONDS=0.5
SUPERSET_MCP_AUTH_TOKEN=

# Local adapter only. Production should use a Superset REST/MCP adapter with
# the deployment's normal secret management.
AI_AGENT_LOCAL_SUPERSET_SECRET_KEY=ai-agent-local-dev-secret-key-not-for-production
