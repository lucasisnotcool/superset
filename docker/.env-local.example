# -----------------------------------------------------------------------
# Example .env-local file for running multiple Superset instances
# Copy this file to .env-local and customize for your setup
# -----------------------------------------------------------------------

# Unique project name prevents container/volume conflicts between clones
# Each clone should have a different name (e.g., superset-pr123, superset-feature-x)
COMPOSE_PROJECT_NAME=superset-dev2

# Host port for the single public Docker entrypoint. Helper scripts export this
# automatically. For plain docker compose commands, pass this file with
# --env-file docker/.env-local when changing the default.
NGINX_HOST_PORT=8090

# Nginx uses Docker service DNS by default. Override an upstream only when that
# service is intentionally run outside Docker.
# SUPERSET_APP_UPSTREAM=superset:8088
# SUPERSET_WEBSOCKET_UPSTREAM=superset-websocket:8080
# SUPERSET_NODE_UPSTREAM=superset-node:9000
# SUPERSET_AI_AGENT_UPSTREAM=superset-ai-agent:5050
#
# Example for running the frontend dev server manually on the host:
# SUPERSET_NODE_UPSTREAM=host.docker.internal:9000

# For verbose logging during development:
# SUPERSET_LOG_LEVEL=debug
