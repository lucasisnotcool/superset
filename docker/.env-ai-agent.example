# Docker smoke tests must use OpenAI or an OpenAI-compatible provider.
# Do not add Ollama settings to this file.

# To start: docker compose -f docker-compose.yml -f docker-compose.ai-agent.yml up --build

AI_AGENT_MODEL_PROVIDER=openai_compatible
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_REQUIRE_API_KEY=true
OPENAI_COMPATIBLE_STRUCTURED_OUTPUT=json_schema

# Alternative direct OpenAI configuration:
# AI_AGENT_MODEL_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini

# Alternative Azure OpenAI configuration:
# AI_AGENT_MODEL_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_MODEL=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_STRUCTURED_OUTPUT=json_schema

# REST is the default smoke-test adapter because it keeps the agent image
# standalone and does not import Superset internals.
SUPERSET_AGENT_ADAPTER=rest
SUPERSET_BASE_URL=http://superset:8088
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin
SUPERSET_AUTH_PROVIDER=db
SUPERSET_AUTH_TOKEN=
SUPERSET_CSRF_TOKEN=
SUPERSET_SQL_POLL_ATTEMPTS=10
SUPERSET_SQL_POLL_INTERVAL_SECONDS=0.5

# MCP can be used after a Superset MCP service is added to the compose stack.
SUPERSET_MCP_URL=http://superset-mcp:5008/mcp
SUPERSET_MCP_AUTH_TOKEN=

AI_AGENT_DEFAULT_SQL_LIMIT=1000
AI_AGENT_MAX_REPAIR_ATTEMPTS=1
AI_AGENT_MAX_CONTEXT_DATASETS=8
AI_AGENT_MAX_SAMPLE_ROWS=5
AI_AGENT_CONVERSATION_STORE=memory
AI_AGENT_MAX_HISTORY_MESSAGES=12
AI_AGENT_MAX_PROMPT_RESULT_ROWS=5
AI_AGENT_MAX_SQL_ITERATIONS=3
AI_AGENT_LOG_LEVEL=INFO
AI_AGENT_SUPPRESS_SUPERSET_LOGS=true
AI_AGENT_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8088,http://localhost:9000
